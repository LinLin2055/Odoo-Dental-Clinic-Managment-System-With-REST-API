<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_dental" model="ir.module.category">
        <field name="name">Dental Clinic</field>
        <field name="sequence">10</field>
    </record>

    <record id="group_dental_user" model="res.groups">
        <field name="name">Dental User</field>
        <field name="category_id" ref="module_category_dental"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_dental_manager" model="res.groups">
        <field name="name">Dental Manager</field>
        <field name="category_id" ref="module_category_dental"/>
        <field name="implied_ids" eval="[(4, ref('group_dental_user'))]"/>
    </record>
</odoo>
